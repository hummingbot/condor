# ── Required ─────────────────────────────────────────
# Create a bot: https://t.me/BotFather
TELEGRAM_TOKEN=

# Get your ID: https://t.me/userinfobot
ADMIN_USER_ID=

# ── Hummingbot API (set by make setup) ───────────────
# DEPLOY_HUMMINGBOT_API=true

# ── Web Dashboard (optional) ─────────────────────────
# Full public URL for the dashboard (include port if needed).
# Used for Telegram /web links AND as the server bind port.
# Examples: http://myserver.com:8088, https://dashboard.example.com
# WEB_URL=http://localhost:8088

# ── Email / SMTP (optional) ──────────────────────────
# Enables the "Email" routine notification hook. Set SMTP_HOST + SMTP_USER
# to turn it on. Recipients are chosen per-routine from the web dashboard.
# Required to enable:
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=you@example.com
# SMTP_PASSWORD=your-app-password
# Optional (sensible defaults shown):
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_FROM defaults to SMTP_USER. Only set it when the login differs from the
# sender address (e.g. SendGrid uses user "apikey") or to add a display name:
# SMTP_FROM=Condor Reports <you@example.com>

