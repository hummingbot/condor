# ── Required ─────────────────────────────────────────
# Create a bot: https://t.me/BotFather
TELEGRAM_TOKEN=

# Get your ID: https://t.me/userinfobot
ADMIN_USER_ID=

# ── Hummingbot API (set by make setup) ───────────────
# DEPLOY_HUMMINGBOT_API=true

# ── Web Dashboard (optional) ─────────────────────────
# Full public URL for the dashboard (include port if needed).
# Used for Telegram /web links AND as the server bind port.
# Examples: http://myserver.com:8088, https://dashboard.example.com
# WEB_URL=http://localhost:8088

# ── AI assistants (/agent chat) ──────────────────────
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# CURSOR_API_KEY=
# CONDOR_CURSOR_CWD=/path/to/checkout    # Cursor local agent cwd (default: repo root)
# CONDOR_NODE_BIN=node                   # Cursor bridge Node binary path
# CONDOR_LOG_CURSOR_BRIDGE_STDERR=1      # Forward Node bridge stderr (often only [condor-bridge] smoke)
# CONDOR_LOG_CURSOR_AGENT_TOOLS=1        # INFO log Cursor tool_use + tool_status (stdout JSON stream)
# CONDOR_MCP_AUDIT_LOG=/tmp/mcp-audit.ndjson  # MCP create_executor request + errors (422/400 bodies when present)
